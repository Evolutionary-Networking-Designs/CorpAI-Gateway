{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/corp-ai",
    "ClientId": "dotnet-ai-client",
    "ClientSecret": "change-this-secret"
  },
  "ReverseProxy": {
    "Clusters": {
      "ollama-cluster": {
        "Destinations": { "destination1": { "Address": "http://ollama:11434" } }
      },
      "keycloak-cluster": {
        "Destinations": { "destination1": { "Address": "http://keycloak:8080" } }
      },
      "openwebui-cluster": {
        "Destinations": { "destination1": { "Address": "http://open-webui:8080" } }
      }
    },
    "Routes": {
      "admin-ollama-route": {
        "ClusterId": "ollama-cluster",
        "Match": { "Path": "/admin/ollama/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/admin/ollama" }],
        "AuthorizationPolicy": "RequireAdmin"
      },
      "admin-keycloak-route": {
        "ClusterId": "keycloak-cluster",
        "Match": { "Path": "/admin/keycloak/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/admin/keycloak" }],
        "AuthorizationPolicy": "RequireAdmin"
      },
      "openwebui-route": {
        "ClusterId": "openwebui-cluster",
        "Match": { "Path": "/webui/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/webui" }],
        "AuthorizationPolicy": "RequireAuthenticatedUser"
      },
      "chat-route": {
        "ClusterId": "ollama-cluster",
        "Match": { "Path": "/api/chat/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/api/chat" }]
      }
    }
  }
}